# Salin ke .env lalu isi nilainya. JANGAN commit .env asli.

# Database MySQL
DATABASE_URL="mysql://root:@127.0.0.1:3306/tokopintar"

# Auth.js (NextAuth v5) — generate: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Domain platform (subdomain routing di middleware)
NEXT_PUBLIC_ROOT_DOMAIN="tokopintar.id"

# Pembayaran langganan (Pakasir) — RAHASIA, server only
PAKASIR_BASE_URL="https://app.pakasir.com"
PAKASIR_PROJECT=""
PAKASIR_API_KEY=""
CRON_SECRET=""

# Email transaksional (Resend / SMTP)
RESEND_API_KEY=""

# Storage (UploadThing / S3 / Cloudinary)
UPLOADTHING_TOKEN=""
